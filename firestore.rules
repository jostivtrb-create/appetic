rules_version = '2';

// Última actualización: 2026-07-16
// Último cambio: el SUPERADMIN administra cualquier local como si fuera el dueño
//   (soporte sin pedirle la cuenta): antes solo podía hacer `update` del local —de ahí
//   el toggle de suscripciones—, pero no escribir productos ni leer pedidos/stats.
//   Ahora los tres pasan por puedeAdministrar() = admin del local O superadmin.
//   Espeja src/config/roles.js → puedeAdministrarLocal(). (Antes: stats/{dia}.)
//
// 🔒 Reglas de Appetic
// - Menú (locales/productos): lectura pública (los clientes ven sin login).
// - Escritura: el admin del local (su correo en local.admins) o el superadmin.
// - Pedidos: cualquiera puede CREAR (registro anónimo para métricas, sin login),
//   pero solo el admin (o el superadmin) los lee. Nadie los edita/borra.
// - Crear/borrar locales: solo desde la consola/seed (nosotros), no desde el cliente.

service cloud.firestore {
  match /databases/{database}/documents {

    function esAdminDe(localId) {
      return request.auth != null
        && request.auth.token.email in get(/databases/$(database)/documents/locales/$(localId)).data.admins;
    }

    // Superadmin (nosotros): controla suscripciones y administra cualquier local. Correo fijo.
    function esSuperadmin() {
      return request.auth != null && request.auth.token.email == 'jostivtrb@gmail.com';
    }

    // ¿Puede administrar ESTE local? El dueño o el superadmin.
    // Espejo de puedeAdministrarLocal() en src/config/roles.js: si cambias uno, cambia el otro.
    function puedeAdministrar(localId) {
      return esAdminDe(localId) || esSuperadmin();
    }

    // Perfil de cada cliente: solo el dueño lo lee/escribe.
    match /usuarios/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /locales/{localId} {
      allow read: if true;
      allow update: if puedeAdministrar(localId);
      allow create, delete: if false;

      match /productos/{productoId} {
        allow read: if true;
        allow write: if puedeAdministrar(localId);
      }

      match /pedidos/{pedidoId} {
        // Registro anónimo: solo crear, con campos mínimos válidos.
        allow create: if request.resource.data.total is number
                      && request.resource.data.total >= 0;
        allow read: if puedeAdministrar(localId);
        allow update, delete: if false;
      }

      match /stats/{statId} {
        // Contadores (visitas/pedidos/monto). El cliente los incrementa anónimo;
        // solo el admin del local (o el superadmin) los lee. Escritura acotada a esos campos.
        allow read: if puedeAdministrar(localId);
        allow write: if request.resource.data.keys().hasOnly(['fecha', 'visitas', 'pedidos', 'monto']);
      }
    }
  }
}
