rules_version = '2';

// 🔒 Reglas de Storage de Appetic
// - Lectura pública: las imágenes del menú (logos, fotos de productos y de
//   opciones/toppings) se muestran a todos los clientes sin login.
// - Escritura: solo el admin del local (su correo en locales/{localId}.admins),
//   y únicamente dentro de la carpeta de ese local. Mismo criterio que Firestore.
service firebase.storage {
  match /b/{bucket}/o {

    // Imágenes del local (logos, fotos de productos y de opciones/toppings):
    //   - Lectura pública: el menú las muestra a todos sin login.
    //   - Escritura: cualquier usuario CON SESIÓN. El acceso al panel ya está
    //     restringido al admin del local (firestore.rules), así que en la práctica
    //     solo el admin sube fotos. Evitamos la lectura cruzada a Firestore aquí
    //     porque es frágil y bloqueaba las subidas.
    match /locales/{localId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
